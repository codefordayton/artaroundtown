DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Railway provides DATABASE_URL automatically in production
# For local dev, SQLite is used by default
DATABASE_URL=sqlite:///db.sqlite3

# Media files — Backblaze B2 in production, local in dev
USE_B2_STORAGE=False
B2_APP_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT_URL=

# Email — console backend in dev, SMTP in production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@artaroundtowndayton.org
